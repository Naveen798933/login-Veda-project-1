# LogicVeda Real-Time Collaboration Platform
# Copy this file to .env.local and fill in your actual values

# ===== SERVER CONFIGURATION =====
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ===== DATABASE =====
MONGODB_URI=mongodb://localhost:27017/logicveda
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/logicveda?retryWrites=true&w=majority

# ===== REDIS =====
REDIS_URI=redis://localhost:6379
# For production: redis://user:password@redis-host:6379

# ===== JWT TOKENS =====
ACCESS_TOKEN_SECRET=your_super_secret_access_token_key_here_change_in_production
REFRESH_TOKEN_SECRET=your_super_secret_refresh_token_key_here_change_in_production
JWT_EXPIRY_ACCESS=15m
JWT_EXPIRY_REFRESH=7d

# ===== EMAIL CONFIGURATION =====
# Development: Use Ethereal (test emails)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_ethereal_email@ethereal.email
SMTP_PASS=your_ethereal_password
SMTP_FROM=noreply@logicveda.com
SMTP_FROM_NAME=LogicVeda Collaboration

# Production: Use your actual SMTP provider
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_TLS=true

# ===== FILE STORAGE =====
# Optional: For production document persistence
STORAGE_TYPE=mongodb
# STORAGE_TYPE=s3
# AWS_S3_BUCKET=your-bucket-name
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_key_id
# AWS_SECRET_ACCESS_KEY=your_secret_key

# ===== LOGGING =====
LOG_LEVEL=info
LOG_FORMAT=json

# ===== CORS & SECURITY =====
CORS_ORIGINS=http://localhost:5173,https://yourdomain.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===== FRONTEND ENVIRONMENT VARIABLES =====
VITE_API_URL=http://localhost:5000
VITE_API_TIMEOUT=10000

# ===== DEPLOYMENT =====
# For Vercel (Frontend)
VERCEL_ENV=development

# For Render/Railway (Backend)
RENDER_ENV=development

# ===== MONITORING =====
SENTRY_DSN=
DATADOG_API_KEY=

# ===== OPTIONAL: GitHub OAuth (Social Login) =====
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_CALLBACK_URL=http://localhost:5000/auth/github/callback
