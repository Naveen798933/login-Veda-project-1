{
  "compilerOptions": {
    "target": "esnext",
    "module": "CommonJS",
    "moduleResolution": "node",
    "allowJs": true,
    // "rootDir": "src",
    "outDir": "dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@collaboration/shared": ["../../packages/shared/index.ts"]
    }
  },
  "include": ["src/**/*", "../../packages/shared/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
